{
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend",
      "entrypoint": "server.js"
    }
  },
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/staff",
      "destination": "/index.html"
    },
    {
      "source": "/staff/:path*",
      "destination": "/index.html"
    }
  ]
}
